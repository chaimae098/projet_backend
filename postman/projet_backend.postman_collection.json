        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.environment.set('token', data.token);",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}",
                  "pm.test('Token returned', function () {",
                  "  pm.expect(data).to.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
